PORT=3000
NODE_ENV=development

# --- Local Postgres (docker-compose uses port 5433) ---
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=retunra

# --- Neon (production) ---
# From Neon: Project → Connect → copy the pooled connection string.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL=

# --- Local Redis (docker-compose) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Upstash (production) ---
# From Upstash: Database → Connect → copy the Redis URL (rediss://...).
# Set as REDIS_URL on Render, or use UPSTASH_REDIS_URL locally.
# REDIS_URL=
# UPSTASH_REDIS_URL=

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# Migrations (TypeORM)
# npm run db:migrate:dev          # apply pending migrations (dev, no build)
# npm run db:migrate              # build + apply migrations locally
# npm run db:migrate:prod         # apply after build (used on Render)
# npm run db:migrate:revert       # revert the last migration
# Add new migrations manually under src/database/migrations/
